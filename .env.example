# ==============================================================================
# VARDAN HOSPITAL AI SAAS — PRODUCTION ENVIRONMENT VARIABLES
# ==============================================================================

# Node configuration
PORT=5000
NODE_ENV=production

# Database Connection (Supabase PostgreSQL URL)
DATABASE_URL="postgresql://postgres:your_db_password_here@db.supabase.co:5432/postgres?schema=public"

# JWT Auth security keys
JWT_SECRET="generate_a_very_long_secure_jwt_signing_key_here"

# CORS Allowed Origin list (comma separated)
ALLOWED_ORIGINS="http://localhost:3000,https://app.techhanu.com"

# AI Triage & Gateway configuration keys
GEMINI_API_KEY="your_google_gemini_free_api_key_here"
GROQ_API_KEY="your_groq_free_api_key_here"

# WhatsApp integration connection settings
# (Sessions and authentication states are saved locally in the ./sessions/ directory)

# Google Sheets app macro sync url
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbxeYqm2NZCcsqgdo2JC7QgRtUXgiKMP9hRcy3vUKzYFxkZ-3kahVBabP6JPIUAy6NF75g/exec"
